---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import MyFace from "../components/MyFace.astro";

import RippleGlass from "../components/RippleGlass.astro";

import { formatRipples, type Ripple, slugify, urlPrefix } from "../ts/utils";
import { createItemListSchema, createWebSiteSchema } from "../ts/schema";

const allRipples = await getCollection("posts");
const ripples: Ripple[] = allRipples
  .filter((ripple) => ripple.data && ripple.data.title)
  .map((ripple) => ({
    data: ripple.data as Ripple["data"],
    url: urlPrefix + slugify(ripple.data.title),
  }));
const formattedRipples = formatRipples(ripples, { limit: 1 });
const structuredData = [
  createWebSiteSchema(),
  createItemListSchema({
    id: "homepage-featured-ripples",
    path: "/",
    name: "Featured ripple",
    description: "The most recent ripple featured on the homepage.",
    items: formattedRipples.map((ripple) => ({
      name: ripple.data.title,
      description: ripple.data.description,
      url: ripple.url,
    })),
  }),
];
---

<MainLayout
  title="Homepage"
  description="Welcome to my website"
  structuredData={structuredData}
>
  <div
    class="mx-6 flex h-full flex-col items-center justify-evenly p-4 lg:flex-row"
  >
    <div
      class="flex max-w-full flex-col-reverse items-center justify-center gap-4 p-4 sm:flex-row"
    >
      <MyFace size="large" priority={true} />
      <div class="flex flex-col gap-4">
        <h2 class="text-xl font-bold">Greetings, I'm</h2>
        <h1
          class="animate-flip-up font-tilt text-neon animate-duration-1000 hover:text-primary hover:shadow-neon hover:text-shadow-glow text-4xl font-bold uppercase transition duration-500 md:text-5xl"
        >
          Dave Tierney
        </h1>
        <p class="text-lg font-semibold">
          Web Developer | Culinarian | Tinkerer
        </p>
      </div>
    </div>
    <div
      class="flex flex-col items-center gap-4 py-4"
      aria-label="Latest Ripple"
    >
      <h2 class="text-lg font-semibold">
        Most recent&nbsp;
        <a
          href="/ripples"
          class="font-tilt text-neon hover:text-primary hover:decoration-neon hover:shadow-neon hover:text-shadow-glow text-xl font-bold uppercase underline transition duration-500 hover:underline sm:no-underline md:text-2xl"
          >ripple</a
        >
      </h2>
      <div class="grid grid-cols-1">
        {
          formattedRipples.map((ripple) => (
            <RippleGlass
              data={ripple.data}
              url={ripple.url}
              showImage={true}
              priority={true}
            />
          ))
        }
      </div>
    </div>
  </div>
</MainLayout>
