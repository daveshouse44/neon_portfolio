---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import RippleGlass from "../../components/RippleGlass.astro";
import Paginate from "../../components/Paginate.astro";
import Wavelengths from "../../components/Wavelengths.astro";

import {
  formatRipples,
  type Ripple,
  type RipplePage,
  slugify,
  urlPrefix,
} from "../../ts/utils";
import { createBlogSchema, createItemListSchema } from "../../ts/schema";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allRipples = await getCollection("posts");
  const ripples: Ripple[] = allRipples
    .filter((ripple) => ripple.data && ripple.data.title)
    .map((ripple) => ({
      data: ripple.data as Ripple["data"],
      url: urlPrefix + slugify(ripple.data.title),
      category: ripple.data.category,
    }));
  const formattedRipples = formatRipples(ripples);

  return paginate(formattedRipples, { pageSize: 6 });
}

const { page }: { page: RipplePage } = Astro.props;
const title = "Ripples";
const description = "A small ripple can spread";

const structuredData = [
  createBlogSchema({
    path: "/ripples/",
    title,
    description,
  }),
  createItemListSchema({
    id: "ripple-items",
    path: Astro.url.pathname,
    name: `${title} archive page`,
    description: "Published ripple posts shown on this archive page.",
    items: page.data.map((ripple) => ({
      name: ripple.data.title,
      description: ripple.data.description,
      url: ripple.url,
    })),
  }),
];
---

<MainLayout
  title={title}
  description={description}
  structuredData={structuredData}
>
  <div
    class="mx-6 flex h-full flex-col justify-center gap-4 p-4"
    aria-label="New Ripples"
  >
    <div class="mt-4 flex flex-col items-center gap-4 text-center">
      <h1 class="text-xl font-bold">
        Sending &nbsp;
        <span
          class="animate-flip-up font-tilt text-neon animate-duration-1000 hover:text-primary hover:shadow-neon hover:text-shadow-glow inline-block text-4xl font-bold uppercase transition duration-500 md:text-5xl"
          >ripples</span
        >
        &nbsp;into the ether
      </h1>
      <Paginate prevUrl={page.url.prev} />
      <div class="my-2 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          page.data.map((ripple, index) => (
            <RippleGlass
              data={ripple.data}
              url={ripple.url}
              style={`--customDelay:${index * 150}ms`}
              class="animate-flip-down animate-delay-(--customDelay) animate-duration-1000"
            />
          ))
        }
      </div>
    </div>
    <Paginate nextUrl={page.url.next} />
    <aside
      class="mb-8 flex flex-col items-center justify-center gap-2 self-center"
      aria-label="Different ripples"
    >
      <h2 class="text-lg font-semibold">Different ripples</h2>
      <Wavelengths showCount={true} />
    </aside>
  </div>
</MainLayout>
