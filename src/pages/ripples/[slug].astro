---
import { getCollection, render } from "astro:content";
import { slugify } from "../../ts/utils";
import RippleLayout from "../../layouts/RippleLayout.astro";
import { createBlogPostingSchema } from "../../ts/schema";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: {
      slug: slugify(post.data.title),
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;

if (!post) {
  return new Response(null, {
    status: 404,
    statusText: "Post not found",
  });
}

// Use the render function to get the processed content
const { Content } = await render(post);

const slug = slugify(post.data.title);
const coverSrc =
  typeof post.data.cover === "string" ? post.data.cover : post.data.cover?.src;

const structuredData = [
  createBlogPostingSchema({
    title: post.data.title,
    description: post.data.description,
    pubDate: post.data.pubDate,
    updated: post.data.updated,
    author: post.data.author,
    category: post.data.category,
    slug,
    coverSrc,
    coverAlt: post.data.coverAlt,
  }),
];
---

<RippleLayout data={post.data} structuredData={structuredData}>
  <Content />
</RippleLayout>
