---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
import ImageWithOverlay from "../components/ImageWithOverlay.astro";
import { Icon } from "astro-icon/components";

import { workLinks, workTabItems } from "../data/workData.tsx";
import ReactTabs from "../components/ReactTabs.tsx";
---

<MainLayout title="Work" description="Jobs and projects">
  <div class="mx-6 flex h-full flex-col items-center justify-center gap-4 p-4">
    <h1 class="mt-4 text-lg font-bold">
      <span
        class="inline-block animate-flip-up font-tilt text-4xl font-bold uppercase text-neon transition duration-500 animate-duration-1000 hover:text-primary hover:shadow-neon hover:text-shadow-glow md:text-5xl"
        >Work&nbsp;</span
      >I have done
    </h1>
    <div class="w-full max-w-5xl md:pb-4">
      <ReactTabs items={workTabItems} client:load />
    </div>
    <h2 class="text-lg font-semibold">
      <span
        class="inline-block animate-flip-up font-tilt text-2xl font-bold uppercase text-neon transition duration-500 animate-duration-1000 hover:text-primary hover:shadow-neon hover:text-shadow-glow"
      >
        Projects&nbsp;
      </span>to see
    </h2>

    <div
      class="mt-2 mb-8 grid w-full max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        workLinks.map((item, index) => (
          <div
            style={`--customDelay:${index * 150}ms`}
            class="group/glass flex animate-flip-down flex-col justify-evenly gap-2 rounded-sm border-2 border-neon border-opacity-40 bg-background bg-opacity-80 p-4 shadow transition duration-300 animate-delay-[var(--customDelay)] animate-duration-1000 hover:border-opacity-100 hover:bg-opacity-100 hover:shadow-glow hover:shadow-neon"
          >
            <Icon
              name={item.icon.name}
              class="h-8 w-8 text-primary transition duration-300 group-hover/glass:text-neon"
            />
            <h3 class="whitespace-nowrap font-tilt text-xl font-bold uppercase text-neon transition duration-500 group-hover/glass:text-primary group-hover/glass:text-shadow-glow ">
              {item.name}
            </h3>
            <p class="w-64 max-w-full">{item.description}</p>
            <Link
              href={item.link}
              text="Go to site"
              icon={{ name: "extlink", side: "right" }}
              target="_blank"
              rel="noopener noreferrer"
            />
            <ImageWithOverlay src={item.image} alt={item.name} />
          </div>
        ))
      }
    </div>
  </div>
</MainLayout>
