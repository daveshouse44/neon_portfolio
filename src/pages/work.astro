---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
import ImageWithOverlay from "../components/ImageWithOverlay.astro";
import { Icon } from "astro-icon/components";

import { workLinks, workTabItems } from "../data/workData.tsx";
import ReactTabs from "../components/ReactTabs.tsx";
---

<MainLayout title="Work" description="Jobs and projects">
  <div class="mx-6 flex h-full flex-col items-center justify-center gap-4 p-4">
    <h1 class="mt-4 text-lg font-bold">
      <span
        class="animate-flip-up font-tilt text-neon animate-duration-1000 hover:text-primary hover:shadow-neon hover:text-shadow-glow inline-block text-4xl font-bold uppercase transition duration-500 md:text-5xl"
        >Work&nbsp;</span
      >I have done
    </h1>
    <div class="w-full max-w-5xl md:pb-4">
      <ReactTabs items={workTabItems} client:load />
    </div>
    <h2 class="text-lg font-semibold">
      <span
        class="animate-flip-up font-tilt text-neon animate-duration-1000 hover:text-primary hover:shadow-neon hover:text-shadow-glow inline-block text-2xl font-bold uppercase transition duration-500"
      >
        Projects&nbsp;
      </span>to see
    </h2>

    <div
      class="mt-2 mb-8 grid w-full max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        workLinks.map((item, index) => (
          <div
            style={`--customDelay:${index * 150}ms`}
            class="group/glass animate-flip-down border-neon/40 bg-background/80 animate-delay-(--customDelay) animate-duration-1000 hover:border-neon hover:bg-background hover:shadow-glow hover:shadow-neon flex flex-col justify-evenly gap-2 rounded-xs border-2 p-4 shadow-sm transition duration-300"
          >
            <Icon
              name={item.icon.name}
              class="text-primary group-hover/glass:text-neon h-8 w-8 transition duration-300"
            />
            <h3 class="font-tilt text-neon group-hover/glass:text-primary group-hover/glass:text-shadow-glow text-xl font-bold whitespace-nowrap uppercase transition duration-500">
              {item.name}
            </h3>
            <p class="w-64 max-w-full">{item.description}</p>
            <Link
              href={item.link}
              text="Go to site"
              icon={{ name: "extlink", side: "right" }}
              target="_blank"
              rel="noopener noreferrer"
              screenReaderText={`Go to the site: ${item.name}`}
            />
            <ImageWithOverlay src={item.image} alt={item.name} />
          </div>
        ))
      }
    </div>
  </div>
</MainLayout>
