---
import { Icon } from "astro-icon/components";
interface Props {
  text: string;
  href: string;
  icon: {
    name: string;
    side: "left" | "right";
  };
  target?: string;
  rel?: string;
  screenReaderText?: string;
}

const { text, href, icon, target, rel, screenReaderText, ...rest } =
  Astro.props as Props;
---

<a
  href={href}
  target={target}
  rel={rel}
  {...rest}
  class="group text-primary inline-flex gap-1 rounded-sm px-1 py-2 font-semibold uppercase transition md:border-0 md:p-0 md:hover:bg-transparent"
>
  {
    icon && icon.side === "left" && (
      <>
        <Icon
          name={icon.name}
          height="24"
          width="24"
          class="group-hover:text-neon transition"
        />
        <div class="flex flex-col">
          <span class="whitespace-nowrap">{text}</span>
          <span class="bg-neon -mt-0.75 h-0.5 max-w-0 transition-all delay-150 duration-500 group-hover:max-w-full group-aria-[current='page']:max-w-full" />
        </div>
      </>
    )
  }

  {
    icon && icon.side === "right" && (
      <>
        <div class="flex flex-col">
          <span class="whitespace-nowrap">{text}</span>
          <span class="bg-neon -mt-0.75 h-0.5 max-w-0 transition-all duration-500 group-hover:max-w-full group-aria-[current='page']:max-w-full" />
        </div>
        <Icon
          name={icon.name}
          height="24"
          width="24"
          class="group-hover:text-neon transition delay-500"
        />
      </>
    )
  }
  <span class="sr-only">{screenReaderText}</span>
</a>
