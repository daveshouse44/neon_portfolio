---
import MainHead from "./MainHead.astro";
import { createWebPageSchema, type SchemaNode } from "../ts/schema";

import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import Theme from "../components/Theme.astro";
import Grid from "../components/Grid.astro";

import "../styles/main.css";
import "@fontsource-variable/albert-sans";
import "@fontsource/tilt-neon";
interface Props {
  title?: string;
  description?: string;
  structuredData?: SchemaNode[];
}

const {
  title = "Dave Tierney's site",
  description = "Creating ripples in my world",
  structuredData = [],
} = Astro.props;

const webPageSchema = createWebPageSchema({
  path: Astro.url.pathname,
  title,
  description,
});

const mergedStructuredData = [webPageSchema, ...structuredData];
---

<html lang="en">
  <MainHead title={title} {description} structuredData={mergedStructuredData} />
  <body class="bg-background text-primary flex h-screen flex-col">
    <Nav />
    <Theme />
    <main class="grow" transition:animate="initial">
      <Grid />
      <slot />
    </main>
    <Footer />
    <script>
      import "../ts/theme";
      import "../ts/neon";
    </script>
  </body>
</html>
