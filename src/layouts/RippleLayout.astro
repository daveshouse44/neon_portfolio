---
import { getCollection } from "astro:content";
import RippleHeader from "../components/RippleHeader.astro";
import Wavelengths from "../components/Wavelengths.astro";
import MainLayout from "../layouts/MainLayout.astro";
import SimilarRipples from "../components/SimilarRipples.astro";

import { formatRipples, type Ripple, slugify } from "../ts/utils";
import type { SchemaNode } from "../ts/schema";

interface Props {
  data: {
    title: string;
    pubDate: string | Date;
    draft: boolean;
    author: string;
    description: string;
    category: string;
    cover?: any;
    coverAlt?: string;
    updated?: string | Date;
  };
  structuredData?: SchemaNode[];
}

const { data, structuredData = [] }: Props = Astro.props;
const {
  title,
  pubDate,
  author,
  description,
  category,
  cover,
  coverAlt,
  updated,
} = data;

const allRipples = await getCollection("posts");
const ripples: Ripple[] = allRipples.map((ripple) => {
  const normalizedPubDate =
    typeof ripple.data.pubDate === "string"
      ? ripple.data.pubDate
      : ripple.data.pubDate.toISOString();

  return {
    data: {
      title: ripple.data.title,
      pubDate: normalizedPubDate,
      draft: ripple.data.draft,
      author: ripple.data.author,
      description: ripple.data.description,
      category: ripple.data.category,
      cover: ripple.data.cover,
      coverAlt: ripple.data.coverAlt,
    },
    url: slugify(ripple.data.title),
    category: ripple.data.category,
  };
});
const formattedRipples = formatRipples(ripples, { sortByDate: false });
const similarRipples = formattedRipples
  .filter(
    (ripple) => ripple.category === category && ripple.data.title !== title,
  )
  .slice(0, 2);
---

<MainLayout
  title={title}
  description={description}
  structuredData={structuredData}
>
  <div class="my-4 grid w-full place-items-center">
    <div class="grid max-w-5xl place-items-center gap-6 p-6">
      <RippleHeader
        title={title}
        pubDate={pubDate}
        author={author}
        category={category}
        cover={cover}
        coverAlt={coverAlt}
        updated={updated}
      />
      <div
        class="bg-background/95 [&>:nth-child(1):first-letter]:font-tilt [&>:nth-child(1):first-letter]:text-neon grid max-w-2xl gap-6 py-5 [&>:nth-child(1):first-letter]:float-left [&>:nth-child(1):first-letter]:mr-1.5 [&>:nth-child(1):first-letter]:text-7xl [&>:nth-child(1):first-letter]:font-bold [&>ol]:list-inside [&>ol]:list-decimal [&>ol]:px-6 [&>p]:px-6 [&>ul]:list-inside [&>ul]:list-disc [&>ul]:px-6"
      >
        <slot />
      </div>
      <aside
        class="mb-8 flex flex-col items-center justify-center gap-2 px-1"
        aria-label="Different waves"
      >
        <h2 class="text-lg font-semibold">Different ripples</h2>
        <Wavelengths showCount={true} />
      </aside>
      <aside
        class="mb-8 flex flex-col items-center justify-center gap-2 px-1"
        aria-label="Similar ripples"
      >
        <h2 class="text-lg font-semibold">Similar ripples</h2>
        <SimilarRipples {similarRipples} />
      </aside>
    </div>
  </div>
</MainLayout>
